          },
          {
            "name": "replacement",
            "annotation": "str",
            "default": "'[REDACTED]'",
            "kwonly": false
          }
        ],
        "args_doc": [
          {
            "name": "default_patterns",
            "desc": "list of regex strings the AUTHOR pins at construction. SECURITY: the model's `filter: {name: \"redact\"}` invocation CANNOT override these \u2014 `apply` ignores any model-supplied `patterns` so the model can neither WIDEN nor NARROW the policy. The allow-list rule applied to filter params."
          },
          {
            "name": "replacement",
            "desc": "string substituted for each match (default `\"[REDACTED]\"`). The model also cannot override this."
          }
        ],
        "method_args_doc": []
      }
