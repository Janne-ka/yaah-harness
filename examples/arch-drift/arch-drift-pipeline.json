{
  "_doc": "Architecture-drift detector (A-only: single model). Snapshot the repo, ask the agent for mermaid markup, render it, diff against the committed SVG, branch on changed, optionally park for human review, land a versioned SVG on approve. Agent uses parse=true (default, ADR-0004) — the model's JSON output is auto-merged onto the payload, so the `render-svg` transform finds `mermaid` directly.",
  "nodes": {
    "role:snapshot":    {"type": "transform", "target": "fn:transforms:snapshot", "call": "envelope"},
    "role:read-svg":    {"type": "transform", "target": "fn:transforms:read_committed_svg", "call": "envelope"},
    "role:extract":     {"type": "agent", "prompt": "file:extract", "model": "claude:claude-sonnet-4-6", "stage": "extract",
                          "carry": ["repo_path", "arch_svg_path", "arch_svg_dir", "committed_svg", "committed_svg_path", "snapshot", "feedback"]},
    "role:render-svg":  {"type": "transform", "target": "fn:transforms:render_mermaid", "call": "envelope"},
    "role:diff":        {"type": "transform", "target": "fn:transforms:diff_svgs", "call": "envelope"},
    "role:report":      {"type": "render", "template_file": "templates/report.html", "out": "diagrams/arch-report.html"},
    "role:report-stamp": {"type": "transform", "target": "fn:transforms:stamp_report", "call": "envelope"},
    "role:gate":        {"type": "human_gate",
                         "ask": "Open the report: examples/arch-drift/diagrams/arch-report.html. {{summary}}. To continue, copy the baton_id printed just above this line and run:  yaah resume <your-root.json> <baton_id> decision.json  — where decision.json is {\"decision\":\"approve\"} (land it) or {\"decision\":\"revise\",\"feedback\":\"...\"}.",
                         "awaiting": "human:arch-review",
                         "form": "approve_or_revise"},
    "role:land":        {"type": "transform", "target": "fn:transforms:write_versioned", "call": "envelope"},
    "role:done":        {"type": "transform", "target": "fn:transforms:noop_done", "call": "envelope"}
  },
  "graph": {
    "start": "snapshot",
    "stages": {
      "snapshot":   {"node": "role:snapshot",   "then": "read-svg"},
      "read-svg":   {"node": "role:read-svg",   "then": "extract"},
      "extract":    {"node": "role:extract", "max_attempts": 2, "feedback": true, "then": "render-svg"},
      "render-svg": {"node": "role:render-svg", "then": "diff"},
      "diff":       {"node": "role:diff",
                     "branch": {"on": "changed", "routes": {"yes": "report", "no": "done"}}},
      "report":     {"node": "role:report",     "then": "report-stamp"},
      "report-stamp": {"node": "role:report-stamp", "then": "gate"},
      "gate":       {"node": "role:gate",
                     "branch": {"on": "decision", "routes": {"approve": "land", "revise": "extract"}}},
      "land":       {"node": "role:land",       "then": null},
      "done":       {"node": "role:done",       "then": null}
    }
  }
}
