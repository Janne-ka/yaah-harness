# run artifacts — regenerated by every run; don't track
.arch-drift-state*/
arch-report*.html
trace*.jsonl
__pycache__/

# diagram outputs — fully regenerable; the pipeline IS what we commit, not its
# output. Keep the dir (via .gitkeep) so the path always resolves; ignore the
# generated SVGs. To commit a specific one as a polished demo: `git add -f
# diagrams/<name>.svg`.
diagrams/*.svg

# private / local run configs + fixtures — machine-specific absolute paths or
# private repo targets (e.g. pointing arch-drift at a sibling app). Keep them
# out of the repo; the committed configs target YAAH itself.
*.private.json
fixtures/*.private.json
