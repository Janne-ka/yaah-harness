{
  "nodes": {
    "role:draft":   {"type": "agent", "prompt": "file:draft",
                     "model": "fake:draft", "stage": "draft"},
    "role:approve": {"type": "human_gate", "awaiting": "review",
                     "ask": "Review the draft:\n\n  {{summary}}\n\nReply {\"decision\": \"approve\"} to publish, or {\"decision\": \"revise\"} to redraft."},
    "role:publish": {"type": "render", "template_file": "templates/published.html",
                     "out": "published.html"}
  },
  "graph": {
    "start": "draft",
    "stages": {
      "draft":   {"node": "role:draft",
                  "max_attempts": 3, "feedback": true, "then": "approve"},
      "approve": {"node": "role:approve",
                  "branch": {"on": "decision", "routes": {"revise": "draft"},
                             "default": "publish"}},
      "publish": {"node": "role:publish", "then": null}
    }
  }
}
