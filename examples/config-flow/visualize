#!/usr/bin/env bash
# visualize — produce a config-flow SVG for any yaah root config.
#
# usage:   ./visualize <path-to-yaah-root-config>
# example: ./visualize ../arch-drift/arch-drift.dogfood-self.json
#          ./visualize ../hello-yaah/starter.local.json
#          ./visualize /abs/path/to/your.json
#
# Output lands in <target-dir>/diagrams/<stem>_<utc>.svg by default; override
# the output dir with the OUTPUT_DIR env var:
#   OUTPUT_DIR=. ./visualize ../hello-yaah/starter.local.json
#
# The pipeline is gateless — config-flow is regenerable, so there's nothing to
# approve. To run it directly:  yaah run config-flow.real.json

set -euo pipefail

if [ $# -lt 1 ]; then
    echo "usage: $0 <path-to-yaah-root-config>" >&2
    echo "       OUTPUT_DIR=<dir> $0 <path>   # override output dir" >&2
    exit 2
fi

TARGET="$1"
if [ ! -f "$TARGET" ]; then
    echo "error: $TARGET is not a file" >&2
    exit 2
fi

# resolve paths absolutely so the temp fixture works from any cwd
TARGET_ABS="$(cd "$(dirname "$TARGET")" && pwd)/$(basename "$TARGET")"
TARGET_DIR="$(dirname "$TARGET_ABS")"
TARGET_BASE="$(basename "$TARGET_ABS")"
TARGET_STEM="${TARGET_BASE%.json}"
STAMP="$(date -u +%Y-%m-%dT%H%MZ)"

# default output: <target-dir>/diagrams/  (alongside the config in a subdir)
OUTPUT_DIR="${OUTPUT_DIR:-$TARGET_DIR/diagrams}"
OUTPUT_DIR_ABS="$(cd "$(dirname "$OUTPUT_DIR")" 2>/dev/null && pwd)/$(basename "$OUTPUT_DIR")" \
    || OUTPUT_DIR_ABS="$OUTPUT_DIR"  # falls back if parent doesn't exist yet (write_versioned mkdirs)
mkdir -p "$OUTPUT_DIR_ABS"

# the SVG name pattern the user asked for: <stem>_<utc>.svg, with a stable
# "latest" alias <stem>.svg sitting next to it
LATEST_NAME="${TARGET_STEM}.svg"

# write a runtime fixture this run will consume (gitignored)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RUNTIME_FIXTURE="$SCRIPT_DIR/fixtures/_runtime.json"
cat > "$RUNTIME_FIXTURE" <<EOF
{
  "_doc": "Generated by visualize on $STAMP — do not edit by hand. Regenerated every run; gitignored.",
  "target_config_path": "$TARGET_ABS",
  "repo_path": "$TARGET_DIR",
  "arch_svg_path": "$OUTPUT_DIR_ABS/$LATEST_NAME",
  "arch_svg_dir": "$OUTPUT_DIR_ABS"
}
EOF

# tiny shim root: extends the real config and overrides `input` to point at
# the runtime fixture we just wrote. (No dogfood layer — the pipeline is
# fully automated, no human gate to auto-approve.)
SHIM_ROOT="$SCRIPT_DIR/_visualize-run.json"
cat > "$SHIM_ROOT" <<EOF
{
  "_extends": "config-flow.real.json",
  "input": "fixtures/_runtime.json"
}
EOF
trap 'rm -f "$SHIM_ROOT"' EXIT

cd "$SCRIPT_DIR"
PYTHONPATH="$(cd "$SCRIPT_DIR/../../src" && pwd)" \
    python3 -m yaah.runtime "$(basename "$SHIM_ROOT")"
