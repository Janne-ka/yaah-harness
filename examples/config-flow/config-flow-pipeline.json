{
  "_doc": "Config-flow visualizer pipeline. Take any yaah root config, describe its _extends chain + pipeline graph + fixture as text, ask the agent to draw a mermaid diagram of that flow, render to SVG, park for human review, land. Same shape as arch-drift A-only but with snapshot_config_flow as the strategy and no diff stage (config-flow is regenerative documentation, not drift detection).",
  "nodes": {
    "role:snapshot":   {"type": "transform", "target": "fn:transforms:snapshot_config_flow", "call": "envelope"},
    "role:extract":    {"type": "agent", "prompt": "file:extract", "model": "claude:claude-sonnet-4-6", "stage": "extract",
                         "carry": ["target_config_path", "arch_svg_path", "arch_svg_dir", "snapshot", "feedback"]},
    "role:check":      {"type": "json_object", "required": ["mermaid"]},
    "role:parse":      {"type": "transform", "target": "fn:transforms:parse_extracted", "call": "envelope"},
    "role:render-svg": {"type": "transform", "target": "fn:transforms:render_mermaid", "call": "envelope"},
    "role:report":     {"type": "render", "template_file": "templates/report.html", "out": "config-flow-report.html"},
    "role:gate":       {"type": "human_gate",
                         "ask": "Review config-flow-report.html. Approve to land the SVG, or revise with feedback.",
                         "awaiting": "human:config-flow-review",
                         "form": "approve_or_revise"},
    "role:land":       {"type": "transform", "target": "fn:transforms:write_versioned", "call": "envelope"}
  },
  "graph": {
    "start": "snapshot",
    "stages": {
      "snapshot":   {"node": "role:snapshot",   "then": "extract"},
      "extract":    {"node": "role:extract",    "validators": ["role:check"], "max_attempts": 2, "feedback": true, "then": "parse"},
      "parse":      {"node": "role:parse",      "then": "render-svg"},
      "render-svg": {"node": "role:render-svg", "then": "report"},
      "report":     {"node": "role:report",     "then": "gate"},
      "gate":       {"node": "role:gate",
                     "branch": {"on": "decision", "routes": {"approve": "land", "revise": "extract"}}},
      "land":       {"node": "role:land",       "then": null}
    }
  }
}
