{
  "_doc": "Config-flow visualizer pipeline. Snapshot the target config, ask the agent to draw it, render, land. Fully automated — no human gate (the artifact is regenerable; the user can re-run any time). Agent uses parse=true (default, ADR-0004) — the model's JSON output is auto-merged onto the payload, so render-svg finds `mermaid` directly. For A/B model comparison, see config-flow-pipeline-ab.json.",
  "nodes": {
    "role:snapshot":   {"type": "transform", "target": "fn:transforms:snapshot_config_flow", "call": "envelope"},
    "role:extract":    {"type": "agent", "prompt": "file:extract-strict", "model": "claude:claude-haiku-4-5", "stage": "extract",
                         "carry": ["target_config_path", "arch_svg_path", "arch_svg_dir", "snapshot"]},
    "role:render-svg": {"type": "transform", "target": "fn:transforms:render_mermaid",  "call": "envelope"},
    "role:land":       {"type": "transform", "target": "fn:transforms:write_versioned", "call": "envelope"}
  },
  "graph": {
    "start": "snapshot",
    "stages": {
      "snapshot":   {"node": "role:snapshot",   "then": "extract"},
      "extract":    {"node": "role:extract",    "max_attempts": 2, "feedback": true, "then": "render-svg"},
      "render-svg": {"node": "role:render-svg", "then": "land"},
      "land":       {"node": "role:land",       "then": null}
    }
  }
}
