{
  "_doc": "A/B variant of config-flow: fork extract to two models (sonnet A vs haiku B). Each agent attaches its own usage via the attacher port (ADR-0003). Fanin merges; prepare computes per-candidate stats; write-both lands BOTH SVGs side-by-side in the same dir with `-a` and `-b` appended. Fully automated — the comparison itself IS the artifact, no gate-picking needed.",
  "nodes": {
    "role:snapshot":     {"type": "transform", "target": "fn:transforms:snapshot_config_flow", "call": "envelope"},

    "role:extract-a":    {"type": "agent", "prompt": "file:extract",
                           "model": "claude:claude-sonnet-4-6", "stage": "extract-a",
                           "carry": ["target_config_path", "repo_path", "arch_svg_path", "arch_svg_dir", "snapshot"],
                           "attach": ["fn:transforms:UsageAttacher"]},
    "role:extract-b":    {"type": "agent", "prompt": "file:extract-strict",
                           "model": "claude:claude-haiku-4-5", "stage": "extract-b",
                           "carry": ["target_config_path", "repo_path", "arch_svg_path", "arch_svg_dir", "snapshot"],
                           "attach": ["fn:transforms:UsageAttacher"]},

    "role:check":        {"type": "json_object", "required": ["mermaid"]},
    "role:parse":        {"type": "transform", "target": "fn:transforms:parse_extracted", "call": "envelope"},
    "role:render-svg":   {"type": "transform", "target": "fn:transforms:render_mermaid",  "call": "envelope"},

    "role:prepare":      {"type": "transform", "target": "fn:transforms:prepare_ab_template", "call": "envelope",
                           "config": {"prices": {
                              "claude-sonnet-4-6": {"in": 3.0, "out": 15.0},
                              "claude-haiku-4-5":  {"in": 0.80, "out": 4.0}}}},

    "role:write-both":   {"type": "transform", "target": "fn:transforms:write_both_candidates", "call": "envelope"}
  },
  "graph": {
    "start": "snapshot",
    "stages": {
      "snapshot":     {"node": "role:snapshot", "then": "fork-extract"},

      "fork-extract": {"node": "", "fork": ["extract-a", "extract-b"], "then": "prepare"},

      "extract-a":    {"node": "role:extract-a", "validators": ["role:check"], "max_attempts": 2, "feedback": true, "then": "parse-a"},
      "parse-a":      {"node": "role:parse",     "then": "render-svg-a"},
      "render-svg-a": {"node": "role:render-svg", "then": "join"},

      "extract-b":    {"node": "role:extract-b", "validators": ["role:check"], "max_attempts": 2, "feedback": true, "then": "parse-b"},
      "parse-b":      {"node": "role:parse",     "then": "render-svg-b"},
      "render-svg-b": {"node": "role:render-svg", "then": "join"},

      "join":         {"node": "",
                       "fanin": {"expect": ["extract-a", "extract-b"], "wait": "all",
                                  "reduce": "fn:transforms:merge_candidates"},
                       "then": null},

      "prepare":      {"node": "role:prepare",    "then": "write-both"},
      "write-both":   {"node": "role:write-both", "then": null}
    }
  }
}
